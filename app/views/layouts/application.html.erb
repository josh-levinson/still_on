<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Still On" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Still On">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="app-body">
    <nav class="navbar">
      <div class="container">
        <%= link_to root_path, class: "navbar-brand" do %>
          <span class="logo-fire-img"></span>
          <span class="logo-still">StillOn</span>
        <% end %>
        <ul class="navbar-nav">
          <% if user_signed_in? %>
            <li><%= link_to "My Groups", groups_path %></li>
            <li><%= button_to "Sign Out", sign_out_path, method: :delete, class: "btn btn-sm btn-outline" %></li>
          <% else %>
            <li><%= link_to "Get Started", onboarding_phone_path, class: "btn btn-sm btn-primary" %></li>
          <% end %>
        </ul>
      </div>
    </nav>

    <% if notice.present? %>
      <div class="container">
        <div class="alert alert-success"><%= notice %></div>
      </div>
    <% end %>

    <% if alert.present? %>
      <div class="container">
        <div class="alert alert-danger"><%= alert %></div>
      </div>
    <% end %>

    <main class="app-main">
      <div class="container">
        <%= yield %>
      </div>
    </main>
  </body>
</html>
