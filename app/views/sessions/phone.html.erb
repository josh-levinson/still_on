<div data-controller="phone-input">
  <div class="onboarding-card-header">
    <h2>Welcome back</h2>
    <p>Enter your phone number and we'll text you a code to sign in.</p>
  </div>

  <% if flash[:error].present? %>
    <div class="onboarding-error"><%= flash[:error] %></div>
  <% end %>

  <%= form_with url: sign_in_submit_phone_path, method: :post, class: "onboarding-form" do |f| %>
    <%= f.telephone_field :phone,
          placeholder: "(555) 000-0000",
          inputmode: "tel",
          autocomplete: "tel-national",
          class: "onboarding-input phone-field",
          data: { action: "input->phone-input#format", phone_input_target: "display" },
          required: true,
          autofocus: true %>

    <%= f.submit "Send code \u2192", class: "btn-onboarding-primary" %>
  <% end %>

  <p class="ob-annotation" style="margin-top: 1.5rem;">
    New here? <%= link_to "Get started \u2192", onboarding_name_path %>
  </p>
</div>
