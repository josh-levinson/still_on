<div class="onboarding-card">
  <div class="onboarding-card-header">
    <h2>Let's get started</h2>
    <p>Tell us a little about you and the hangout.</p>
  </div>

  <% if flash[:error].present? %>
    <div class="onboarding-error"><%= flash[:error] %></div>
  <% end %>

  <%= form_with url: onboarding_submit_name_path, method: :post, class: "onboarding-form" do |f| %>
    <div class="form-group">
      <%= f.label :first_name, "Your first name" %>
      <%= f.text_field :first_name,
            placeholder: "Alex",
            class: "onboarding-input",
            value: session[:ob_first_name],
            autocomplete: "given-name",
            required: true,
            autofocus: true %>
    </div>

    <div class="form-group">
      <%= f.label :hangout_name, "What's the hangout called?" %>
      <%= f.text_field :hangout_name,
            placeholder: "Friday Night Poker",
            class: "onboarding-input",
            value: session[:ob_hangout_name],
            required: true %>
    </div>

    <%= f.submit "Continue", class: "btn-onboarding-primary" %>
  <% end %>
</div>
