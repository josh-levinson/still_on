<div class="onboarding-card" data-controller="cadence">
  <div class="onboarding-card-header">
    <h2>How often?</h2>
    <p>StillOn will send "Still on?" reminders before each one.</p>
  </div>

  <% if flash[:error].present? %>
    <div class="onboarding-error"><%= flash[:error] %></div>
  <% end %>

  <%= form_with url: onboarding_submit_cadence_path, method: :post, class: "onboarding-form", data: { cadence_target: "form" } do |f| %>
    <%= f.hidden_field :cadence, data: { cadence_target: "input" } %>

    <div class="cadence-options">
      <button type="button"
              class="cadence-btn"
              data-cadence-value="weekly"
              data-action="click->cadence#select">
        <span class="cadence-icon">&#128197;</span>
        <span class="cadence-label">Every week</span>
        <span class="cadence-sub">Weekly reminders, automatically</span>
      </button>

      <button type="button"
              class="cadence-btn"
              data-cadence-value="monthly"
              data-action="click->cadence#select">
        <span class="cadence-icon">&#128198;</span>
        <span class="cadence-label">Every month</span>
        <span class="cadence-sub">Monthly reminders, automatically</span>
      </button>

      <button type="button"
              class="cadence-btn"
              data-cadence-value="none"
              data-action="click->cadence#select">
        <span class="cadence-icon">&#9728;&#65039;</span>
        <span class="cadence-label">Just this once</span>
        <span class="cadence-sub">One-time event, no repeat</span>
      </button>
    </div>
  <% end %>
</div>
