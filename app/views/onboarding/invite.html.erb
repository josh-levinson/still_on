<div data-controller="clipboard">
  <p class="ob-label">Step <%= @step %> of 6 &middot; Invite</p>
  <div class="onboarding-card-header">
    <h2>Bring your people in.</h2>
    <p>Share a link &mdash; they can RSVP without signing up.</p>
  </div>

  <div class="invite-hangout-card">
    <p class="invite-hangout-label">Your hangout</p>
    <p class="invite-hangout-name"><%= @hangout_name %></p>
    <p class="invite-hangout-meta">
      <%= @date.strftime("%A, %B %-d") %> &middot;
      <% case @cadence
         when "weekly" %>Weekly
      <% when "monthly" %>Monthly
      <% else %>One-time
      <% end %>
    </p>
  </div>

  <div class="invite-link-box">
    <span class="invite-link-text" data-clipboard-target="source"><%= @invite_url %></span>
    <button class="invite-copy-btn"
            data-action="click->clipboard#copy"
            data-clipboard-target="button">
      Copy
    </button>
  </div>

  <div class="invite-share-btns">
    <a href="sms:&body=<%= ERB::Util.url_encode("Hey! RSVP for #{@hangout_name} here: #{@invite_url}") %>"
       class="share-btn">
      📱 iMessage
    </a>
    <a href="https://wa.me/?text=<%= ERB::Util.url_encode("Hey! RSVP for #{@hangout_name} here: #{@invite_url}") %>"
       target="_blank"
       rel="noopener"
       class="share-btn">
      💬 WhatsApp
    </a>
  </div>

  <%= link_to "Go to my hangout \u2192",
        group_event_event_occurrence_path(@occurrence.event.group, @occurrence.event, @occurrence),
        class: "btn-onboarding-primary" %>
  <p class="ob-annotation">Takes 5 seconds to RSVP</p>
</div>
