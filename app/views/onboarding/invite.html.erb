<div class="onboarding-card onboarding-invite" data-controller="clipboard">
  <div class="invite-success-badge">
    <span class="invite-checkmark">&#10003;</span>
  </div>

  <div class="onboarding-card-header">
    <h2>You're all set, <%= @first_name %>!</h2>
    <p>Here's everything coming up for <strong><%= @hangout_name %></strong>.</p>
  </div>

  <div class="invite-summary">
    <div class="summary-row">
      <span class="summary-icon">&#128197;</span>
      <span class="summary-text">
        First meetup: <strong><%= @date.strftime("%A, %B %-d") %></strong>
      </span>
    </div>
    <div class="summary-row">
      <span class="summary-icon">&#128259;</span>
      <span class="summary-text">
        <% case @cadence
           when "weekly" %>Repeats every week
        <% when "monthly" %>Repeats every month
        <% else %>One-time event
        <% end %>
      </span>
    </div>
    <div class="summary-row">
      <span class="summary-icon">&#128241;</span>
      <span class="summary-text">
        We'll text everyone "Still on?" 2 days before each meetup
      </span>
    </div>
  </div>

  <div class="invite-section">
    <p class="invite-section-label">Share with your crew</p>

    <div class="invite-link-box">
      <span class="invite-link-text" data-clipboard-target="source"><%= @invite_url %></span>
      <button class="invite-copy-btn"
              data-action="click->clipboard#copy"
              data-clipboard-target="button">
        Copy
      </button>
    </div>

    <div class="invite-share-btns">
      <a href="sms:&body=<%= ERB::Util.url_encode("Hey! RSVP for #{@hangout_name} here: #{@invite_url}") %>"
         class="share-btn share-imessage">
        iMessage
      </a>
      <a href="https://wa.me/?text=<%= ERB::Util.url_encode("Hey! RSVP for #{@hangout_name} here: #{@invite_url}") %>"
         target="_blank"
         rel="noopener"
         class="share-btn share-whatsapp">
        WhatsApp
      </a>
    </div>
  </div>

  <div class="onboarding-actions">
    <%= link_to "Go to my hangout", group_event_event_occurrence_path(@occurrence.event.group, @occurrence.event, @occurrence), class: "btn-onboarding-primary" %>
  </div>
</div>
