<div class="onboarding-card" data-controller="date-picker">
  <div class="onboarding-card-header">
    <h2>When's the first one?</h2>
    <p>Pick a date for the first meetup.</p>
  </div>

  <% if flash[:error].present? %>
    <div class="onboarding-error"><%= flash[:error] %></div>
  <% end %>

  <%= form_with url: onboarding_submit_date_path, method: :post, class: "onboarding-form" do |f| %>
    <%= f.hidden_field :date, value: session[:ob_date], data: { date_picker_target: "value" } %>

    <div class="quick-date-options">
      <button type="button"
              class="quick-date-btn"
              data-action="click->date-picker#selectQuick"
              data-date="<%= @this_friday.to_s %>">
        <span class="quick-date-label">This Friday</span>
        <span class="quick-date-sub"><%= @this_friday.strftime("%b %-d") %></span>
      </button>

      <button type="button"
              class="quick-date-btn"
              data-action="click->date-picker#selectQuick"
              data-date="<%= @next_friday.to_s %>">
        <span class="quick-date-label">Next Friday</span>
        <span class="quick-date-sub"><%= @next_friday.strftime("%b %-d") %></span>
      </button>

      <button type="button"
              class="quick-date-btn"
              data-action="click->date-picker#showCustom">
        <span class="quick-date-label">Pick a date</span>
        <span class="quick-date-sub">Custom</span>
      </button>
    </div>

    <div class="custom-date-wrapper" data-date-picker-target="custom" style="display:none;">
      <%= f.date_field :custom_date,
            class: "onboarding-input",
            min: Date.today.to_s,
            data: { action: "change->date-picker#selectCustom", date_picker_target: "customInput" } %>
    </div>

    <div class="selected-date-display" data-date-picker-target="display" style="display:none;">
      Selected: <strong data-date-picker-target="label"></strong>
    </div>

    <%= f.submit "Continue", class: "btn-onboarding-primary", data: { date_picker_target: "submit" }, disabled: session[:ob_date].blank? %>
  <% end %>
</div>
