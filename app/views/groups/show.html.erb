<div class="group-show">
  <div class="group-header">
    <% if @group.avatar_url.present? %>
      <%= image_tag @group.avatar_url, alt: @group.name, class: "group-avatar-large" %>
    <% end %>
    <div class="group-info">
      <h1><%= @group.name %></h1>
      <% if @group.description.present? %>
        <p class="group-description"><%= @group.description %></p>
      <% end %>
      <div class="group-meta">
        <span><%= pluralize(@group.members.count, 'member') %></span>
        <% if @group.is_private %>
          <span class="badge">Private</span>
        <% end %>
      </div>
    </div>
    <div class="group-actions">
      <% if @group.organizer?(current_user) %>
        <%= link_to "Edit Group", edit_group_path(@group.slug), class: "btn btn-secondary" %>
      <% end %>
      <% if @group.created_by == current_user %>
        <%= button_to "Delete Group", group_path(@group.slug), method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-danger" %>
      <% end %>
    </div>
  </div>

  <% if (@group.created_by == current_user || @group.member?(current_user)) && @upcoming_occurrences.any? %>
    <div class="rsvp-summary-section">
      <div class="section-header">
        <h2>Upcoming</h2>
      </div>
      <div class="rsvp-summary-list">
        <% member_count = @group.group_memberships.count %>
        <% @upcoming_occurrences.each do |occurrence| %>
          <%= link_to group_event_event_occurrence_path(@group.slug, occurrence.event, occurrence), class: "rsvp-summary-row" do %>
            <div class="rsvp-summary-event">
              <span class="rsvp-summary-title"><%= occurrence.event.title %></span>
              <span class="rsvp-summary-date"><%= occurrence.start_time.strftime("%a %b %-d") %></span>
            </div>
            <div class="rsvp-summary-counts">
              <span class="rsvp-count attending"><%= occurrence.attending_count %> in</span>
              <span class="rsvp-count-sep">·</span>
              <span class="rsvp-count maybe"><%= occurrence.maybe_count %> maybe</span>
              <span class="rsvp-count-sep">·</span>
              <span class="rsvp-count no-response"><%= occurrence.no_response_count(member_count) %> no response</span>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>

  <div class="events-section">
    <div class="section-header">
      <h2>Events</h2>
      <% if @group.organizer?(current_user) %>
        <%= link_to "Create Event", new_group_event_path(@group.slug), class: "btn btn-primary" %>
      <% end %>
    </div>

    <% if @events.any? %>
      <div class="events-list">
        <% @events.each do |event| %>
          <div class="event-card">
            <%= link_to group_event_path(@group.slug, event) do %>
              <h3><%= event.title %></h3>
              <% if event.description.present? %>
                <p><%= truncate(event.description, length: 150) %></p>
              <% end %>
              <div class="event-meta">
                <% if event.recurrence_type != "none" %>
                  <span class="badge"><%= event.recurrence_type.titleize %></span>
                <% end %>
                <span><%= pluralize(event.event_occurrences.upcoming.count, 'upcoming occurrence') %></span>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="empty-state">
        <p>No events yet.</p>
        <% if @group.organizer?(current_user) %>
          <%= link_to "Create the first event", new_group_event_path(@group.slug), class: "btn btn-primary" %>
        <% end %>
      </div>
    <% end %>
  </div>

  <% if @group.organizer?(current_user) %>
    <div class="members-section">
      <div class="section-header">
        <h2>Members</h2>
      </div>
      <div class="members-list">
        <% @group.group_memberships.includes(:user).each do |membership| %>
          <div class="member-row">
            <span class="member-name">
              <%= membership.user.first_name %> <%= membership.user.last_name %>
              <% if @group.created_by == membership.user %>
                <span class="badge">Owner</span>
              <% elsif membership.organizer? %>
                <span class="badge">Co-organizer</span>
              <% end %>
            </span>
            <span class="member-actions">
              <% unless @group.created_by == membership.user %>
                <% if membership.organizer? %>
                  <%= button_to "Remove co-organizer", demote_group_group_membership_path(@group.slug, membership.user_id), method: :post, class: "btn btn-secondary btn-sm" %>
                <% else %>
                  <%= button_to "Make co-organizer", promote_group_group_membership_path(@group.slug, membership.user_id), method: :post, class: "btn btn-secondary btn-sm" %>
                <% end %>
              <% end %>
            </span>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
